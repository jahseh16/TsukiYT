<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/r6"
    android:layout_width="315dp"
    android:layout_height="match_parent">
    <TextView
        android:textSize="14sp"
        android:textColor="@color/zv"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:id="@+id/flat_multi_title"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:layout_marginTop="10dp"
        android:maxLines="2"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="50dp"
        app:layout_constraintTop_toTopOf="0"/>
    <com.flatads.sdk.core.domain.ui.common.AlikeMultiAdView
        android:id="@+id/flat_multi_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        app:layout_constraintBottom_toTopOf="@+id/flat_multi_desc"
        app:layout_constraintTop_toBottomOf="@+id/flat_multi_title"/>
    <TextView
        android:textColor="@color/zv"
        android:ellipsize="end"
        android:id="@+id/flat_multi_desc"
        android:layout_width="0dp"
        android:layout_height="20dp"
        android:layout_marginTop="12dp"
        android:maxLines="1"
        android:layout_marginEnd="30dp"
        app:layout_constraintEnd_toEndOf="0"
        app:layout_constraintStart_toStartOf="@+id/flat_multi_title"
        app:layout_constraintTop_toBottomOf="@+id/flat_multi_view"/>
    <TextView
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/zv"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/flat_multi_btn"
        android:background="@drawable/cc"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:layout_width="206dp"
        android:layout_height="38dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="25dp"
        android:text="Buy Now"
        android:maxLines="1"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        app:layout_constraintBottom_toBottomOf="0"
        app:layout_constraintEnd_toEndOf="0"
        app:layout_constraintStart_toStartOf="0"
        app:layout_constraintTop_toBottomOf="@+id/flat_multi_desc"/>
    <ImageView
        android:id="@+id/flat_iv_circle"
        android:visibility="gone"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:src="@mipmap/u"
        app:layout_constraintBottom_toBottomOf="@+id/flat_multi_btn"
        app:layout_constraintEnd_toEndOf="@+id/flat_multi_btn"
        app:layout_constraintStart_toStartOf="@+id/flat_multi_btn"
        app:layout_constraintTop_toTopOf="@+id/flat_multi_btn"/>
</androidx.constraintlayout.widget.ConstraintLayout>
