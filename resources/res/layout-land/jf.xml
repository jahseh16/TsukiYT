<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/flat_image_layout"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        app:layout_constraintEnd_toEndOf="0"
        app:layout_constraintStart_toEndOf="@+id/flat_more_app">
        <ImageView
            android:id="@+id/flat_fuzzy_image"
            android:background="#eaf8f4"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            app:layout_constraintEnd_toStartOf="@+id/flat_landscape_detail"
            app:layout_constraintStart_toStartOf="0"/>
        <ImageView
            android:id="@+id/center_image"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            app:layout_constraintEnd_toStartOf="@+id/flat_landscape_detail"
            app:layout_constraintStart_toStartOf="0"/>
        <include
            android:id="@+id/flat_landscape_detail"
            android:layout_width="280dp"
            android:layout_height="match_parent"
            app:layout_constraintEnd_toEndOf="0"
            layout="@layout/k3"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <com.flatads.sdk.core.domain.ui.common.FlatMoreAppView
        android:id="@+id/flat_more_app"
        android:visibility="gone"
        android:layout_width="77dp"
        android:layout_height="match_parent"
        app:layout_constraintStart_toStartOf="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
