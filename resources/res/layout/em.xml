<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/icon_group"
    android:layout_width="@dimen/qh"
    android:layout_height="@dimen/qg">
    <ImageView
        android:id="@+id/icon"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/qy"
        android:layout_marginBottom="@dimen/qy"
        android:scaleType="centerInside"
        android:layout_marginStart="@dimen/qy"
        android:layout_marginEnd="@dimen/qy"/>
    <ImageView
        android:layout_gravity="end|bottom"
        android:id="@+id/right_icon"
        android:visibility="gone"
        android:layout_width="@dimen/ql"
        android:layout_height="@dimen/ql"
        android:layout_marginBottom="8dp"
        android:scaleType="centerInside"
        android:layout_marginEnd="8dp"/>
</FrameLayout>
