<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:tag="layout/fragment_feedback_submit_0"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <include
        android:id="@+id/include_toolbar"
        app:layout_constraintEnd_toEndOf="0"
        app:layout_constraintStart_toStartOf="0"
        app:layout_constraintTop_toTopOf="0"
        layout="@layout/pv"/>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/include_toolbar">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_dialog"
            android:tag="binding_1"
            android:paddingBottom="60dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center_vertical"
                android:id="@+id/llAdTips"
                android:tag="binding_2"
                android:background="?attr/l3"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="12dp"
                app:layout_constraintTop_toTopOf="0">
                <TextView
                    android:textSize="12sp"
                    android:textColor="?attr/l4"
                    android:id="@+id/tvAdTips"
                    android:tag="binding_3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="12dp"/>
                <androidx.appcompat.widget.AppCompatImageView
                    android:tag="binding_4"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    app:srcCompat="@drawable/q5"/>
            </LinearLayout>
            <TextView
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/fig"
                android:id="@+id/tv_type"
                android:tag="binding_5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/rsj"
                android:layout_marginStart="16dp"
                app:layout_constrainedWidth="true"
                app:layout_constraintEnd_toStartOf="@+id/tv_typeContent"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintHorizontal_chainStyle="2"
                app:layout_constraintStart_toStartOf="0"
                app:layout_constraintTop_toBottomOf="@+id/llAdTips"/>
            <TextView
                android:textSize="16sp"
                android:textColor="?attr/fig"
                android:gravity="start"
                android:id="@+id/tv_typeContent"
                android:tag="binding_6"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="16dp"
                app:layout_constrainedWidth="true"
                app:layout_constraintBottom_toBottomOf="@+id/tv_type"
                app:layout_constraintEnd_toEndOf="0"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintStart_toEndOf="@+id/tv_type"
                app:layout_constraintTop_toTopOf="@+id/tv_type"/>
            <EditText
                android:textSize="14sp"
                android:textColor="?attr/fig"
                android:textColorHint="#868686"
                android:id="@+id/et_input"
                android:tag="binding_7"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginRight="16dp"
                android:hint="@string/fml"
                android:textCursorDrawable="@drawable/lm"
                app:layout_constraintDimensionRatio="h, 262:134"
                app:layout_constraintTop_toBottomOf="@+id/tv_type"
                style="@style/vf"/>
            <LinearLayout
                android:gravity="start"
                android:orientation="horizontal"
                android:id="@+id/ll_pic"
                android:tag="binding_8"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginRight="16dp"
                app:layout_constraintTop_toBottomOf="@+id/et_input">
                <include
                    android:id="@+id/il_pic_1"
                    layout="@layout/l3"/>
                <include
                    android:id="@+id/il_pic_2"
                    layout="@layout/l3"/>
                <include
                    android:id="@+id/il_pic_3"
                    layout="@layout/l3"/>
            </LinearLayout>
            <TextView
                android:textSize="13sp"
                android:textColor="?attr/fig"
                android:gravity="start"
                android:id="@+id/tv_contact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginRight="16dp"
                android:text="@string/fmu"
                app:layout_constraintTop_toBottomOf="@+id/ll_pic"/>
            <EditText
                android:textSize="14sp"
                android:textColor="?attr/fig"
                android:textColorHint="#868686"
                android:id="@+id/et_contact"
                android:tag="binding_9"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginRight="16dp"
                android:hint="@string/fmg"
                android:textCursorDrawable="@drawable/lm"
                app:layout_constraintTop_toBottomOf="@+id/tv_contact"
                style="@style/ye"/>
            <include
                android:id="@+id/progressBar"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:indeterminateOnly="true"
                android:indeterminateDuration="200"
                android:indeterminateBehavior="repeat"
                app:layout_constraintBottom_toBottomOf="0"
                app:layout_constraintEnd_toEndOf="0"
                app:layout_constraintStart_toStartOf="0"
                app:layout_constraintTop_toTopOf="0"
                layout="@layout/mr"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
    <TextView
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:gravity="center"
        android:id="@+id/tv_positive"
        android:tag="binding_10"
        android:background="@drawable/fds"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="46dp"
        android:layout_marginRight="46dp"
        android:layout_marginBottom="30dp"
        android:text="@string/f8d"
        android:textAllCaps="true"
        app:layout_constraintBottom_toBottomOf="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
