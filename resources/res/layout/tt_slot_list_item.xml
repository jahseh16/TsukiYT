<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#fff"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:id="@+id/slot_layout"
        android:background="@drawable/tt_mediation_card_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:layout_marginTop="4dp"
        android:layout_marginRight="8dp"
        android:layout_marginBottom="4dp">
        <ImageView
            android:id="@+id/adn_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginLeft="15dp"
            android:layout_marginTop="19dp"/>
        <TextView
            android:textSize="13sp"
            android:textColor="@color/tt_color_666"
            android:gravity="center"
            android:id="@+id/adn_name"
            android:layout_width="wrap_content"
            android:layout_height="20dp"
            android:layout_marginLeft="8dp"
            android:layout_marginTop="19dp"
            android:text="pangle"
            android:includeFontPadding="false"
            android:layout_toRightOf="@+id/adn_icon"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/tt_color_333"
            android:gravity="start|center_vertical"
            android:id="@+id/slot_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="19dp"
            android:minHeight="20dp"
            android:layout_below="@+id/adn_icon"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="6dp"
            android:layout_toStartOf="@+id/show_ad"/>
        <TextView
            android:textSize="11sp"
            android:textColor="#fff"
            android:gravity="center"
            android:id="@+id/bidding_ad"
            android:background="@drawable/tt_rit_bidding_bg_shape"
            android:padding="2dp"
            android:visibility="visible"
            android:layout_width="wrap_content"
            android:layout_height="20dp"
            android:layout_marginLeft="8dp"
            android:layout_marginTop="19dp"
            android:layout_marginBottom="19dp"
            android:text="bidding"
            android:layout_toRightOf="@+id/adn_name"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/tt_load_status_color_selector"
            android:gravity="center"
            android:id="@+id/slot_load_status"
            android:background="@drawable/tt_ad_load_bg_selector"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_marginTop="12dp"
            android:layout_marginRight="15dp"
            android:layout_alignParentRight="true"/>
        <Button
            android:textSize="8dp"
            android:textColor="#fff"
            android:gravity="center"
            android:id="@+id/show_ad"
            android:background="@drawable/tt_ad_load_btn_bg_shape"
            android:visibility="gone"
            android:layout_width="38dp"
            android:layout_height="20dp"
            android:layout_marginTop="6dp"
            android:text="Show Ad"
            android:layout_below="@+id/slot_load_status"
            android:layout_marginEnd="15dp"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
</LinearLayout>
