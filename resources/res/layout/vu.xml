<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:tag="layout/video_detail_player_error_normal_0"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="36dp"
    android:paddingEnd="36dp">
    <ImageView
        android:id="@+id/ivIconSmall"
        android:tag="binding_1"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/fjv"
        app:layout_constraintBottom_toBottomOf="0"
        app:layout_constraintStart_toStartOf="0"
        app:layout_constraintTop_toTopOf="0"
        app:layout_constraintVertical_bias="0.244"/>
    <TextView
        android:textSize="14dp"
        android:textColor="#ffffff"
        android:id="@+id/detail_player_error_title"
        android:tag="binding_2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        app:layout_constraintEnd_toEndOf="0"
        app:layout_constraintStart_toEndOf="@+id/ivIconSmall"
        app:layout_constraintTop_toTopOf="@+id/ivIconSmall"/>
    <TextView
        android:textSize="11dp"
        android:textColor="#888888"
        android:id="@+id/detail_player_error_subtitle"
        android:tag="binding_3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        app:layout_constraintEnd_toEndOf="@+id/detail_player_error_title"
        app:layout_constraintStart_toStartOf="@+id/detail_player_error_title"
        app:layout_constraintTop_toBottomOf="@+id/detail_player_error_title"/>
    <TextView
        android:textSize="14dp"
        android:textStyle="bold"
        android:textColor="@color/zo"
        android:gravity="center"
        android:id="@+id/detail_player_error_action"
        android:tag="binding_4"
        android:background="@drawable/hq"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="17dp"
        android:foreground="?attr/fu5"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        app:layout_constraintEnd_toEndOf="0"
        app:layout_constraintStart_toStartOf="0"
        app:layout_constraintTop_toBottomOf="@+id/detail_player_error_subtitle"/>
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:id="@+id/llPrevious"
        android:tag="binding_5"
        android:background="@drawable/hc"
        android:layout_width="wrap_content"
        android:layout_height="30dp"
        android:minWidth="100dp"
        app:layout_constraintBottom_toBottomOf="0"
        app:layout_constraintEnd_toStartOf="@+id/llNext"
        app:layout_constraintHorizontal_chainStyle="2"
        app:layout_constraintStart_toStartOf="0"
        app:layout_constraintTop_toTopOf="0"
        app:layout_constraintVertical_bias="0.91">
        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            app:srcCompat="@drawable/fsq"/>
        <TextView
            android:textSize="11dp"
            android:textColor="#ffffff"
            android:gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="@string/rbz"
            android:layout_marginStart="4dp"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:id="@+id/llNext"
        android:tag="binding_6"
        android:background="@drawable/hc"
        android:layout_width="wrap_content"
        android:layout_height="30dp"
        android:minWidth="100dp"
        android:layout_marginStart="12dp"
        app:layout_constraintBottom_toBottomOf="0"
        app:layout_constraintEnd_toEndOf="0"
        app:layout_constraintStart_toEndOf="@+id/llPrevious"
        app:layout_constraintTop_toTopOf="0"
        app:layout_constraintVertical_bias="0.9">
        <TextView
            android:textSize="11dp"
            android:textColor="#ffffff"
            android:gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="@string/rbp"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginStart="4dp"
            app:srcCompat="@drawable/fsc"/>
    </LinearLayout>
    <ImageView
        android:tag="binding_7"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:src="@drawable/fjv"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toBottomOf="0"
        app:layout_constraintEnd_toEndOf="0"
        app:layout_constraintStart_toStartOf="0"
        app:layout_constraintTop_toTopOf="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
