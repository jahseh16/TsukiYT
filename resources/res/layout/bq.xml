<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutFansZoneBottomEntrance"
    android:tag="layout/fans_zone_layout_bottom_entrance_0"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <FrameLayout
        android:id="@+id/flNormalIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivIcon"
            android:layout_width="@dimen/u7"
            android:layout_height="@dimen/u7"
            app:layout_constraintBottom_toBottomOf="0"
            app:layout_constraintEnd_toEndOf="0"
            app:layout_constraintStart_toStartOf="0"
            app:layout_constraintTop_toTopOf="0"
            app:srcCompat="?attr/fi2"/>
    </FrameLayout>
    <FrameLayout
        android:id="@+id/flToggleAnim"
        android:layout_width="@dimen/u7"
        android:layout_height="@dimen/u7">
        <com.opensource.svgaplayer.SVGAImageView
            android:id="@+id/ivToggleAnim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerInside"
            app:layout_constraintBottom_toBottomOf="0"
            app:layout_constraintEnd_toEndOf="0"
            app:layout_constraintStart_toStartOf="0"
            app:layout_constraintTop_toTopOf="0"/>
    </FrameLayout>
</FrameLayout>
