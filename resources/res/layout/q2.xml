<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/clGuideContainer"
    android:tag="layout/layout_short_video_guide_0"
    android:background="@color/r8"
    android:focusable="true"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/iv_guide_icon1"
        android:tag="binding_1"
        android:layout_width="@dimen/gc"
        android:layout_height="@dimen/gt"
        android:layout_marginBottom="@dimen/gi"
        android:translationX="@dimen/gm"
        app:layout_constraintBottom_toBottomOf="@+id/iv_guide_hand1"
        app:layout_constraintStart_toStartOf="@+id/iv_guide_hand1"
        app:srcCompat="@drawable/fks"/>
    <ImageView
        android:id="@+id/iv_guide_hand1"
        android:tag="binding_2"
        android:layout_width="@dimen/gg"
        android:layout_height="@dimen/gy"
        android:layout_marginBottom="@dimen/gj"
        android:layout_marginStart="@dimen/gu"
        app:layout_constraintBottom_toTopOf="@+id/tv_guide_text"
        app:layout_constraintEnd_toEndOf="0"
        app:layout_constraintStart_toStartOf="0"
        app:srcCompat="@drawable/fb4"/>
    <ImageView
        android:id="@+id/iv_guide_icon2"
        android:tag="binding_3"
        android:layout_width="@dimen/go"
        android:layout_height="@dimen/gp"
        android:layout_marginBottom="@dimen/gq"
        android:translationX="@dimen/gz"
        app:layout_constraintBottom_toBottomOf="@+id/iv_guide_hand2"
        app:layout_constraintStart_toStartOf="@+id/iv_guide_hand2"
        app:srcCompat="@drawable/fkl"/>
    <ImageView
        android:id="@+id/iv_guide_hand2"
        android:tag="binding_4"
        android:layout_width="@dimen/gl"
        android:layout_height="@dimen/gx"
        android:layout_marginBottom="@dimen/gh"
        android:layout_marginStart="@dimen/gd"
        app:layout_constraintBottom_toTopOf="@+id/tv_guide_text"
        app:layout_constraintEnd_toEndOf="0"
        app:layout_constraintStart_toStartOf="0"
        app:srcCompat="@drawable/fb5"/>
    <TextView
        android:textSize="20sp"
        android:textColor="@color/zv"
        android:gravity="center"
        android:id="@+id/tv_guide_text"
        android:tag="binding_5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="17dp"
        app:layout_constraintBottom_toBottomOf="0"
        app:layout_constraintEnd_toEndOf="0"
        app:layout_constraintStart_toStartOf="0"
        app:layout_constraintTop_toTopOf="0"
        app:layout_constraintVertical_bias="@dimen/po"/>
    <TextView
        android:textSize="16sp"
        android:textColor="@color/j6"
        android:gravity="center"
        android:id="@+id/tv_ok"
        android:tag="binding_6"
        android:background="@drawable/xl"
        android:layout_width="110dp"
        android:layout_height="40dp"
        android:layout_marginBottom="65dp"
        app:layout_constraintBottom_toBottomOf="0"
        app:layout_constraintEnd_toEndOf="0"
        app:layout_constraintStart_toStartOf="0"/>
    <ImageView
        android:id="@+id/iv_close"
        android:tag="binding_7"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginTop="66dp"
        android:layout_marginEnd="36dp"
        app:layout_constraintEnd_toEndOf="0"
        app:layout_constraintTop_toTopOf="0"
        app:srcCompat="@drawable/fs7"/>
</androidx.constraintlayout.widget.ConstraintLayout>
