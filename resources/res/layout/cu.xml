<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutMixesItemRoot"
    android:tag="layout/layout_mixes_big_item_0"
    android:background="@drawable/fx8"
    android:paddingBottom="@dimen/g4"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/g4"
    android:contentDescription="YTB_BIG"
    android:paddingStart="@dimen/uk"
    android:paddingEnd="@dimen/uk">
    <free.daily.tube.image_loader.view.RecyclerImageView
        android:id="@+id/ivThumbnail"
        android:tag="binding_1"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true"
        app:layout_constraintDimensionRatio="h,1080:606"
        app:layout_constraintEnd_toEndOf="0"
        app:layout_constraintStart_toStartOf="0"
        app:layout_constraintTop_toTopOf="0"/>
    <View
        android:id="@+id/viewLayout"
        android:background="@drawable/flp"
        android:layout_width="148dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="@+id/ivThumbnail"
        app:layout_constraintEnd_toEndOf="@+id/ivThumbnail"
        app:layout_constraintTop_toTopOf="@+id/ivThumbnail"/>
    <TextView
        android:textSize="14sp"
        android:textColor="#ffffffff"
        android:id="@+id/tvVideoCount"
        android:tag="binding_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@+id/ivVideoCount"
        app:layout_constraintEnd_toEndOf="@+id/viewLayout"
        app:layout_constraintStart_toStartOf="@+id/viewLayout"
        app:layout_constraintTop_toTopOf="@+id/viewLayout"
        app:layout_constraintVertical_chainStyle="2"/>
    <ImageView
        android:id="@+id/ivVideoCount"
        android:layout_width="@dimen/u7"
        android:layout_height="@dimen/u7"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toBottomOf="@+id/viewLayout"
        app:layout_constraintEnd_toEndOf="@+id/viewLayout"
        app:layout_constraintStart_toStartOf="@+id/viewLayout"
        app:layout_constraintTop_toBottomOf="@+id/tvVideoCount"
        app:srcCompat="@drawable/vu"/>
    <ImageView
        android:id="@+id/musicEntrance"
        android:background="?attr/fu5"
        android:padding="4dp"
        android:focusable="true"
        android:visibility="gone"
        android:clickable="true"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="3dp"
        app:layout_constraintBottom_toBottomOf="@+id/ivFeedMore"
        app:layout_constraintEnd_toStartOf="@+id/ivFeedMore"
        app:layout_constraintTop_toTopOf="@+id/ivFeedMore"
        app:srcCompat="@drawable/wz"/>
    <ImageView
        android:id="@+id/ivFeedMore"
        android:background="?attr/fu6"
        android:padding="4dp"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="@dimen/g4"
        android:layout_marginEnd="8dp"
        app:layout_constraintEnd_toEndOf="0"
        app:layout_constraintTop_toBottomOf="@+id/ivThumbnail"
        app:srcCompat="@drawable/oo"/>
    <TextView
        android:textSize="@dimen/hb"
        android:textStyle="bold"
        android:textColor="?attr/fig"
        android:ellipsize="end"
        android:id="@+id/tvTitle"
        android:tag="binding_3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:maxLines="2"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="4dp"
        app:layout_constraintEnd_toStartOf="@+id/musicEntrance"
        app:layout_constraintStart_toStartOf="0"
        app:layout_constraintTop_toBottomOf="@+id/ivThumbnail"
        app:layout_goneMarginStart="12dp"/>
    <TextView
        android:textSize="@dimen/hs"
        android:textColor="?attr/fih"
        android:ellipsize="end"
        android:id="@+id/tvDetail"
        android:tag="binding_4"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:maxLines="1"
        android:singleLine="true"
        app:layout_constraintEnd_toEndOf="@+id/tvTitle"
        app:layout_constraintStart_toStartOf="@+id/tvTitle"
        app:layout_constraintTop_toBottomOf="@+id/tvTitle"/>
</androidx.constraintlayout.widget.ConstraintLayout>
