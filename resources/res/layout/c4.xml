<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:tag="layout/layout_not_interested_two_column_video_item_0"
    android:background="?attr/fu5"
    android:paddingTop="8dp"
    android:paddingBottom="14dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:contentDescription="YTB_TWO_COLUMN"
    android:paddingStart="5dp"
    android:paddingEnd="5dp">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/ivThumbnail"
        android:tag="binding_1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scaleType="fitXY"
        android:adjustViewBounds="true"
        app:layout_constraintDimensionRatio="h,1:1"
        app:layout_constraintEnd_toEndOf="0"
        app:layout_constraintStart_toStartOf="0"
        app:layout_constraintTop_toTopOf="0"/>
    <ProgressBar
        android:id="@+id/progress"
        android:tag="binding_2"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:max="100"
        android:progressDrawable="@drawable/fxh"
        android:layoutDirection="ltr"
        android:layout_marginStart="1.5dp"
        android:layout_marginEnd="1.5dp"
        app:layout_constraintBottom_toBottomOf="@+id/ivThumbnail"
        app:layout_constraintEnd_toEndOf="@+id/ivThumbnail"
        app:layout_constraintStart_toStartOf="@+id/ivThumbnail"
        style="@android:style/Widget.ProgressBar.Horizontal"/>
    <TextView
        android:textSize="10sp"
        android:textColor="#ffffff"
        android:id="@+id/tvDuration"
        android:tag="binding_3"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintBottom_toBottomOf="@+id/ivThumbnail"
        app:layout_constraintEnd_toEndOf="@+id/ivThumbnail"/>
    <ImageView
        android:id="@+id/ivAvatar"
        android:tag="binding_4"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginTop="8dp"
        app:layout_constraintStart_toStartOf="0"
        app:layout_constraintTop_toBottomOf="@+id/ivThumbnail"/>
    <TextView
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="?attr/fig"
        android:ellipsize="end"
        android:id="@+id/tvTitle"
        android:tag="binding_5"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:maxLines="2"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        app:layout_constraintEnd_toStartOf="@+id/ivFeedMore"
        app:layout_constraintStart_toEndOf="@+id/ivAvatar"
        app:layout_constraintTop_toBottomOf="@+id/ivThumbnail"
        app:layout_goneMarginStart="12dp"/>
    <ImageView
        android:id="@+id/ivFeedMore"
        android:background="?attr/fu6"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginTop="8dp"
        app:layout_constraintEnd_toEndOf="0"
        app:layout_constraintStart_toEndOf="@+id/tvTitle"
        app:layout_constraintTop_toBottomOf="@+id/ivThumbnail"
        app:srcCompat="@drawable/oo"/>
    <TextView
        android:textSize="@dimen/hs"
        android:textColor="?attr/fih"
        android:ellipsize="end"
        android:id="@+id/tvDetail"
        android:tag="binding_6"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:maxLines="2"
        android:includeFontPadding="false"
        app:layout_constraintEnd_toEndOf="@+id/tvTitle"
        app:layout_constraintStart_toStartOf="@+id/tvTitle"
        app:layout_constraintTop_toBottomOf="@+id/tvTitle"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/root_not_interested"
        android:background="@drawable/xp"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="0"
        app:layout_constraintTop_toTopOf="0">
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintDimensionRatio="h, 1:1"
            app:layout_constraintTop_toTopOf="0">
            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginTop="50dp"
                app:srcCompat="@drawable/fry"/>
            <TextView
                android:textSize="14sp"
                android:textColor="#ccffffff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rb0"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/jd"
                android:gravity="center"
                android:id="@+id/tvUndo"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/rsy"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
