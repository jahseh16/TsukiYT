<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:tag="layout/fragment_short_video_0"
    android:background="@color/r6"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.viewpager2.widget.ViewPager2
        android:orientation="vertical"
        android:id="@+id/viewPager"
        android:tag="binding_1"
        android:saveEnabled="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <View
        android:id="@+id/topShadow"
        android:background="@drawable/fd5"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="@+id/barrier_top_search"
        app:layout_constraintTop_toTopOf="0"/>
    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/barrier_top_search"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="3"
        app:constraint_referenced_ids="ivBack,flTopSearch"/>
    <androidx.constraintlayout.widget.Group
        android:tag="binding_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:constraint_referenced_ids="topShadow,flTopSearch"/>
    <FrameLayout
        android:id="@+id/flTopSearch"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        app:layout_constraintEnd_toEndOf="0"
        app:layout_constraintStart_toEndOf="@+id/ivBack"
        app:layout_constraintTop_toTopOf="0"
        app:layout_goneMarginStart="16dp"/>
    <androidx.constraintlayout.widget.Guideline
        android:orientation="horizontal"
        android:id="@+id/guide_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_begin="48dp"/>
    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/barrier_guide_btm"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="3"
        app:constraint_referenced_ids="flTopSearch,guide_back"/>
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/v_comments_container"
        android:saveEnabled="false"
        android:layout_width="match_parent"
        android:layout_height="360dp"
        app:layout_constraintBottom_toBottomOf="0"/>
    <ImageView
        android:id="@+id/ivBack"
        android:background="?attr/fu6"
        android:padding="@dimen/of"
        android:visibility="gone"
        android:saveEnabled="false"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="@dimen/z9"
        app:layout_constraintBottom_toBottomOf="@+id/barrier_guide_btm"
        app:layout_constraintStart_toStartOf="0"
        app:layout_constraintTop_toTopOf="0"
        app:srcCompat="@drawable/fb2"/>
    <include
        android:id="@+id/loadingView"
        android:saveEnabled="false"
        android:layout_width="@dimen/g6"
        android:layout_height="@dimen/g6"
        app:layout_constraintBottom_toBottomOf="0"
        app:layout_constraintEnd_toEndOf="0"
        app:layout_constraintStart_toStartOf="0"
        app:layout_constraintTop_toTopOf="0"
        layout="@layout/ms"/>
    <include
        android:id="@+id/errorView"
        android:background="@color/zv"
        android:saveEnabled="false"
        layout="@layout/q4"/>
    <ViewStub
        android:id="@+id/vs_guide"
        android:saveEnabled="false"
        android:layout="@layout/q2"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <FrameLayout
        android:tag="@string/fcg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
