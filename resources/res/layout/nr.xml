<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:tag="layout/playlist_video_list_item_0"
    android:background="?attr/a5"
    android:paddingBottom="8dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_image"
        android:tag="binding_1"
        android:layout_width="132dp"
        android:layout_height="74dp"
        android:layout_marginTop="8dp"
        android:scaleType="centerCrop"
        android:layout_marginStart="18dp"
        app:layout_constraintStart_toStartOf="0"
        app:layout_constraintTop_toTopOf="0"/>
    <TextView
        android:textAppearance="?android:attr/textAppearanceSmall"
        android:textSize="10dp"
        android:textColor="@color/xr"
        android:id="@+id/tv_duration"
        android:tag="binding_2"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:textAllCaps="true"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:layout_marginEnd="4dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_image"
        app:layout_constraintEnd_toEndOf="@+id/iv_image"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/ivDrag"
        android:tag="binding_3"
        android:visibility="gone"
        android:layout_width="82dp"
        android:layout_height="0dp"
        android:scaleType="center"
        android:paddingEnd="63dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_image"
        app:layout_constraintStart_toStartOf="0"
        app:layout_constraintTop_toTopOf="@+id/iv_image"
        app:srcCompat="?attr/za"/>
    <TextView
        android:textAppearance="?android:attr/textAppearanceLarge"
        android:textSize="14dp"
        android:textColor="?attr/fig"
        android:id="@+id/tv_name"
        android:tag="binding_4"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:maxLines="2"
        android:layout_marginStart="12dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_image"
        app:layout_constraintEnd_toStartOf="@+id/v_options"
        app:layout_constraintStart_toEndOf="@+id/iv_image"
        app:layout_constraintTop_toTopOf="@+id/iv_image"/>
    <ImageView
        android:id="@+id/v_options"
        android:tag="binding_5"
        android:background="?attr/fu6"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:layout_marginEnd="4dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_image"
        app:layout_constraintEnd_toEndOf="0"
        app:layout_constraintTop_toTopOf="@+id/iv_image"
        app:srcCompat="?attr/c0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
