<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="false">
        <shape>
            <corners android:radius="@dimen/y9"/>
            <solid android:color="@color/xw"/>
            <padding
                android:left="12dp"
                android:top="3dp"
                android:right="12dp"
                android:bottom="3dp"/>
        </shape>
    </item>
    <item android:state_selected="true">
        <shape>
            <corners android:radius="@dimen/y9"/>
            <solid android:color="@color/xm"/>
            <padding
                android:left="12dp"
                android:top="3dp"
                android:right="12dp"
                android:bottom="3dp"/>
        </shape>
    </item>
</selector>
