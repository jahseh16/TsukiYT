<?xml version="1.0" encoding="utf-8"?>
<animated-selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:state_checked="true"
        android:id="@+id/on"
        android:drawable="@drawable/dg"/>
    <item
        android:id="@+id/off"
        android:drawable="@drawable/dy"/>
    <transition
        android:drawable="@drawable/dh"
        android:toId="@+id/off"
        android:fromId="@+id/on"/>
    <transition
        android:drawable="@drawable/du"
        android:toId="@+id/on"
        android:fromId="@+id/off"/>
</animated-selector>
